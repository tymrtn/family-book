# Required
SECRET_KEY=          # 64-char hex: python -c "import secrets; print(secrets.token_hex(32))"
FERNET_KEY=          # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BASE_URL=http://localhost:8000

# Database (defaults to sqlite:///data/family.db)
# DATABASE_URL=sqlite:///data/family.db
# DATA_DIR=/data

# Facebook OAuth (optional — set FB_ENABLED=true to activate)
# FB_ENABLED=false
# FB_APP_ID=
# FB_APP_SECRET=

# Admin emails (comma-separated) — persons with these emails get is_admin=true
# ADMIN_EMAILS=

# Approval (if true, invite claims require admin approval)
# REQUIRE_APPROVAL=false

# Magic link email via Envelope API
# ENVELOPE_API_URL=
# ENVELOPE_API_KEY=
# ENVELOPE_ACCOUNT_ID=

# Inbound email webhook
# ENVELOPE_WEBHOOK_SECRET=

# Notifications (all optional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TELEGRAM_BOT_TOKEN=
# WHATSAPP_BUSINESS_PHONE_ID=
# WHATSAPP_BUSINESS_TOKEN=
# SIGNAL_BRIDGE_URL=

# Matrix (optional)
# MATRIX_HOMESERVER=http://localhost:6167
# MATRIX_BOT_USER=
# MATRIX_BOT_PASSWORD=
# MATRIX_FAMILY_ROOM=

# Logging
# LOG_LEVEL=INFO
# PORT=8000
